<Window x:Class="Quantyx.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        Height="768" Width="1580">
    <Border Background="#161616" CornerRadius="20">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="75"></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="1">
                <RadioButton Foreground="White" Height="75" HorizontalAlignment="Stretch" VerticalContentAlignment="Center" Content="Core" Cursor="Hand"></RadioButton>
                <RadioButton Foreground="White" Height="75" HorizontalAlignment="Stretch" VerticalContentAlignment="Center" Content="Metrics" Cursor="Hand"></RadioButton>
                <RadioButton Foreground="White" Height="75" HorizontalAlignment="Stretch" VerticalContentAlignment="Center" Content="Performance" Cursor="Hand"></RadioButton>
                <RadioButton Foreground="White" Height="75" HorizontalAlignment="Stretch" VerticalContentAlignment="Center" Content="Processes" Cursor="Hand"></RadioButton>
                <RadioButton Foreground="White" Height="75" HorizontalAlignment="Stretch" VerticalContentAlignment="Center" Content="Overlay" Cursor="Hand"></RadioButton>
                <RadioButton Foreground="White" Height="75" HorizontalAlignment="Stretch" VerticalContentAlignment="Center" Content="Settings" Cursor="Hand"></RadioButton>
            </StackPanel>

            <Border Grid.Column="1" HorizontalAlignment="Right">
                <Button Background="Red" Width="20" Height="20" Margin="15" Style="{StaticResource ButtonBorder}" Click="BtnClose_Button">X</Button>
            </Border>
        
            <Border Grid.RowSpan="7" Grid.Row="1" Grid.Column="1">
                <Grid Margin="100">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    <TextBlock Margin="25" Grid.Row="0" Grid.Column="0" FontSize="50" Foreground="white">CPU USAGE: 30%</TextBlock>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
