<Window x:Class="Quantyx.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        Height="768" Width="1580">
    <Border Background="#161616" CornerRadius="20">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Background="#161B22" CornerRadius="20,0,0,20">
            </Border>
            <Border Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Grid.Column="0" Grid.ColumnSpan="2" CornerRadius="20,20,0,0" Background="Transparent">
            </Border>
            <StackPanel Grid.Row="1">
                <RadioButton Foreground="White" Height="115" Margin="30,0,0,0" HorizontalAlignment="Stretch" VerticalContentAlignment="Center" Content="Core" Cursor="Hand" Style="{StaticResource RadioBtn}"></RadioButton>
                <RadioButton Foreground="White" Height="115" Margin="30,0,0,0" HorizontalAlignment="Stretch" VerticalContentAlignment="Center" Content="Metrics" Cursor="Hand" Style="{StaticResource RadioBtn}"></RadioButton>
                <RadioButton Foreground="White" Height="115" Margin="30,0,0,0" HorizontalAlignment="Stretch" VerticalContentAlignment="Center" Content="Performance" Cursor="Hand" Style="{StaticResource RadioBtn}"></RadioButton>
                <RadioButton Foreground="White" Height="115" Margin="30,0,0,0" HorizontalAlignment="Stretch" VerticalContentAlignment="Center" Content="Processes" Cursor="Hand" Style="{StaticResource RadioBtn}"></RadioButton>
                <RadioButton Foreground="White" Height="115" Margin="30,0,0,0" HorizontalAlignment="Stretch" VerticalContentAlignment="Center" Content="Overlay" Cursor="Hand" Style="{StaticResource RadioBtn}"></RadioButton>
                <RadioButton Foreground="White" Height="115" Margin="30,0,0,0" HorizontalAlignment="Stretch" VerticalContentAlignment="Center" Content="Settings" Cursor="Hand" Style="{StaticResource RadioBtn}"></RadioButton>
            </StackPanel>
            
            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Width="20" Height="20" Margin="0,17.5,0,15" Style="{StaticResource ButtonMinimize}" Click="BtnMinimize_Button">
                    <Image Source= "/Assets/minimize.png"/>
                </Button>
                <Button Width="15" Height="15" Margin="3,17.5,20,15" Style="{StaticResource ButtonBorder}" Click="BtnClose_Button">
                    <Image Source= "/Assets/close.png"/>
                </Button>
            </StackPanel>

                <Border Grid.Row="1" Grid.Column="1">
                <Grid Margin="100">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    <TextBlock Margin="25" Grid.Row="0" Grid.Column="0" FontSize="50" Foreground="white">CPU USAGE: 30%</TextBlock>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
